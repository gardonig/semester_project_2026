# Python caches
__pycache__/
*.py[cod]
*$py.class

# Virtual environments
venv/
env/
.venv/
.medsam_venv/
.vibeseg_venv/
.totalseg_venv

# Cloned external tool repositories
tools/

# Large data directories (not tracked)
data/datasets/*
data/predictions/*

# Poset session files (user-generated, not tracked)
data/posets/tests/*
data/posets/merged_sessions/*
data/Output_constructed_posets/*.json

# OS specific files
.DS_Store
Thumbs.db

# Large generated tensors
assets/visible_human_tensors/*
!assets/visible_human_tensors/.gitkeep
assets/visible_human_male/

# Keep empty directory markers
!data/Output_constructed_posets/.gitkeep

# Instruction documents
scripts/generate_instructions_docx.py
Anatomical_Poset_Builder_Instructions.docx

